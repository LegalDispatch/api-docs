    "/api/v1/service-requests/{id}/submit": {
      "post": {
        "tags": [
          "Submission"
        ],
        "summary": "Submit a draft service request",
        "description": "Submits a **draft** service request. This triggers:\n1. Completeness validation (parties, locations, documents)\n2. Payment hold placement via Payment Service\n3. Work order creation in Operations Service\n4. Status transition to `submitted` (or `fee_review` if partner requires)\n\nThe `payment_method_id` identifies the payment source for the hold.",
        "operationId": "SubmitServiceRequest",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitServiceRequestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Payment Required"
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          },
          "422": {
            "description": "Unprocessable Entity"
          }
        }
      }
    },
    "/api/v1/service-requests/{id}/cancel": {
      "post": {
        "tags": [
          "Service Requests"
        ],
        "summary": "Cancel a service request",
        "description": "Cancels a service request. Only allowed for orders in a pre-`in_progress` status\n(`draft`, `fee_review`, `submitted`, `assigned`).\n\nCancellation releases any payment hold and cancels the Operations work order if one exists.",
        "operationId": "CancelServiceRequest",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
