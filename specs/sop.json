    "/api/v1/service-requests/{id}/approve-fees": {
      "post": {
        "tags": [
          "Fees"
        ],
        "summary": "Approve or adjust fees",
        "description": "Approves or adjusts the fee line items for a service request in `fee_review` status.\n\n### Actions\n- `approve` — accept all fees as-is and proceed to submission\n- `adjust` — modify specific fee line item amounts before approval\n\nWhen adjusting, provide an `adjustments` array with fee line item IDs and new amounts.\nThe estimated fee is recalculated from the adjusted line items.\nAfter approval, the order transitions to `submitted`.",
        "operationId": "ApproveFees",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
