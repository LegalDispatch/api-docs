{
  "openapi": "3.0.1",
  "info": {
    "title": "LegalDispatch Service of Process API",
    "description": "Service of process business logic, compliance, and proof generation for the\nLegalDispatch platform. Manages order lifecycle, fee line items, party tracking,\npartner transfers, and proof of service generation.\n\n## Authentication Model\n- **Public endpoints** — `Authorization: Bearer <access_token>` (JWT from API Gateway)\n- **Internal endpoints** — `X-Internal-Token: <shared_secret>` (service-to-service only)\n\n## Response Format\nAll responses use **snake_case** JSON serialization. Error responses follow the\nstandard envelope: `{ \"code\": \"CODE\", \"message\": \"...\", \"details\": {...}, \"request_id\": \"...\" }`.",
    "contact": {
      "name": "LegalDispatch Engineering",
      "email": "engineering@legaldispatch.io"
    },
    "license": {
      "name": "Proprietary"
    },
    "version": "v1"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Liveness probe",
        "description": "Returns **200 OK** if the process is running.\nDoes not verify downstream dependencies — use `/ready` for that.",
        "operationId": "Liveness",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Readiness probe",
        "description": "Checks all critical dependencies and returns **200** only when the primary\ndatabase is reachable.\n\n- **Cache** and **event bus** are reported but non-critical — the service\n  degrades gracefully if they are temporarily unavailable.\n- Each dependency check has a **5-second timeout** — a timed-out check\n  reports `\"timeout\"` instead of `\"disconnected\"`.\n- Returns **503** when a critical dependency is unreachable.",
        "operationId": "Readiness",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { }
              }
            }
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    },
    "/api/v1/service-requests": {
      "get": {
        "tags": [
          "Service Requests"
        ],
        "summary": "List service requests",
        "description": "Returns a paginated list of service requests for the authenticated user's partner.\nSupports filtering by **status**, free-text **search** (order number, case number),\nsorting, and pagination.\n\n### Query Parameters\n- `status` — filter by status (e.g., `draft`, `submitted`, `in_progress`)\n- `search` — free-text search across order number and case number\n- `sort_by` — column to sort by (default: `created_at`)\n- `sort_direction` — `asc` or `desc` (default: `desc`)\n- `page` — page number, 1-based (default: `1`)\n- `page_size` — items per page, 1–100 (default: `25`)",
        "operationId": "ListServiceRequests",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort_direction",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponseOfServiceRequestResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Service Requests"
        ],
        "summary": "Create a new service request",
        "description": "Creates a new service request in **draft** status. The request may include\nparties and locations inline. Fee calculation is performed immediately via PMS.\n\nSet `client_id` to create an order on behalf of a client.",
        "operationId": "CreateServiceRequest",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateServiceRequestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Entity"
          }
        }
      }
    },
