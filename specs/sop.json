            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    },
    "/api/v1/service-requests/{id}/accept-transfer": {
      "post": {
        "tags": [
          "Transfers"
        ],
        "summary": "Accept or reject a transfer",
        "description": "The receiving partner accepts or rejects a pending transfer.\n\n- **Accept**: Order ownership transfers, fees are recalculated, and the work order\n  is re-created under the new partner.\n- **Reject**: The transfer is cancelled, the order reverts to `submitted` status\n  under the original partner, and a refund is issued.\n\nThe `decision` field must be `accept` or `reject`. When rejecting,\n`rejection_reason` should be provided.",
        "operationId": "AcceptOrRejectTransfer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptTransferRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    },
    "/api/v1/service-requests/{id}/additional-fees": {
      "post": {
        "tags": [
          "Fees"
        ],
        "summary": "Add an additional fee",
        "description": "Adds an additional fee to a service request that is in `submitted`, `assigned`,\n`dispatched`, or `in_progress` status.\n\nIf `charge_immediately` is `true`, the fee is charged via Payment Service immediately.\nOtherwise, the fee is tracked and charged upon order completion.\n\nFee types: `mileage`, `wait_time`, `rush`, `after_hours`, `stakeout`, `skip_trace`, `other`.",
        "operationId": "AddAdditionalFee",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
