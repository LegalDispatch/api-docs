            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    },
    "/api/v1/service-requests/{id}/transfer": {
      "post": {
        "tags": [
          "Transfers"
        ],
        "summary": "Initiate a partner transfer",
        "description": "Initiates a transfer of the service request to another partner.\nThe target partner's acceptance is checked via PMS before the transfer is created.\n\nOnly allowed for orders in `submitted` status. The order transitions to `pending_transfer`\nuntil the target partner accepts or rejects.",
        "operationId": "InitiateTransfer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
